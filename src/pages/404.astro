---
import Layout from "../layouts/Layout.astro"
---

<Layout title="404: Not Found">
  <section
    class="flex flex-1 items-center border-b border-line/70 px-5 py-20 sm:px-8"
  >
    <div class="mx-auto w-full max-w-6xl">
      <p class="font-code text-sm text-accent uppercase">04 / Not found</p>
      <div
        class="mt-5 grid gap-8 border-t border-line pt-8 md:grid-cols-[0.7fr_1fr] md:items-end"
      >
        <h1
          class="font-code text-[clamp(6rem,20vw,13rem)] leading-[0.75] font-bold text-accent-2"
        >
          404
        </h1>
        <div class="md:pb-2">
          <h2 class="text-3xl font-bold text-white sm:text-4xl">
            This page is not here.
          </h2>
          <p class="mt-3 max-w-md leading-relaxed text-muted">
            The link may have moved, or the address may be incorrect.
          </p>
          <a
            href="/"
            class="mt-7 inline-flex min-h-11 items-center justify-center gap-2 rounded-md bg-accent px-5 py-2.5 font-semibold text-bg transition-colors hover:bg-white motion-reduce:transition-none"
          >
            <span aria-hidden="true">&#8592;</span>
            <span>Return home</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
