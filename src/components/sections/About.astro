---
import { getCollection } from "astro:content"
import SkillItem from "./SkillItem.astro"

const skills = (await getCollection("skills")).sort(
  (a, b) => a.data.order - b.data.order,
)
const icons = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/images/skills/*.svg",
  { eager: true },
)

const skillsByTitle = new Map(skills.map(skill => [skill.data.title, skill]))
const skillGroups = [
  {
    title: "Core",
    skills: ["HTML", "CSS", "JavaScript", "TypeScript", "Python"],
  },
  {
    title: "Frontend",
    skills: ["Tailwind CSS", "React", "Svelte", "Vue", "Astro", "Next.js"],
  },
  {
    title: "Backend & data",
    skills: ["Node.js", "Express", "MongoDB", "MySQL", "Firebase"],
  },
  {
    title: "Tools & platforms",
    skills: ["Git", "Docker", "Magento 2", "WordPress"],
  },
].map(group => ({
  ...group,
  skills: group.skills
    .map(title => skillsByTitle.get(title))
    .filter(skill => skill !== undefined),
}))
---

<section
  id="about"
  class="border-b border-line/70 bg-bg px-5 py-24 sm:px-8 lg:py-28"
>
  <div class="mx-auto max-w-6xl">
    <header
      class="grid gap-5 border-t border-line pt-5 md:grid-cols-[1fr_minmax(18rem,0.65fr)] md:items-end"
    >
      <div>
        <p class="font-code text-sm text-accent uppercase">02 / About</p>
        <h2 class="mt-3 max-w-3xl text-4xl font-bold text-white sm:text-5xl">
          Delivery thinking. Development craft.
        </h2>
      </div>
      <p class="max-w-xl leading-relaxed text-muted md:justify-self-end">
        A practical approach to turning complex requirements into clear,
        maintainable digital products.
      </p>
    </header>

    <div class="mt-14 grid gap-14 lg:grid-cols-12 lg:gap-10">
      <div class="lg:col-span-4">
        <p class="text-xl leading-relaxed text-gray-200">
          I work across project delivery and web development, combining clear
          planning with hands-on implementation.
        </p>
        <p class="mt-5 leading-relaxed text-muted">
          The focus is on useful interfaces, sensible technical choices and
          systems that remain easy to understand.
        </p>

        <dl class="mt-10 grid gap-5 sm:grid-cols-3 lg:grid-cols-1">
          <div class="border-t border-line pt-4">
            <dt class="font-code text-sm text-accent-2 uppercase">Clarify</dt>
            <dd class="mt-2 text-sm leading-relaxed text-muted">
              Define the real problem and remove unnecessary complexity.
            </dd>
          </div>
          <div class="border-t border-line pt-4">
            <dt class="font-code text-sm text-accent-2 uppercase">Build</dt>
            <dd class="mt-2 text-sm leading-relaxed text-muted">
              Turn the plan into an accessible, responsive product.
            </dd>
          </div>
          <div class="border-t border-line pt-4">
            <dt class="font-code text-sm text-accent-2 uppercase">Refine</dt>
            <dd class="mt-2 text-sm leading-relaxed text-muted">
              Test the details and improve what users actually experience.
            </dd>
          </div>
        </dl>
      </div>

      <div class="grid gap-x-8 gap-y-10 sm:grid-cols-2 lg:col-span-8">
        {
          skillGroups.map(group => (
            <section class="border-t border-line pt-4">
              <h3 class="font-code text-sm text-gray-300 uppercase">
                {group.title}
              </h3>
              <div class="mt-4 grid grid-cols-2 gap-2">
                {group.skills.map(skill => (
                  <SkillItem
                    title={skill.data.title}
                    icon={
                      icons[`../../assets/images/skills/${skill.data.icon}`]
                        .default
                    }
                    iconAlt={skill.data.icon_alt}
                  />
                ))}
              </div>
            </section>
          ))
        }
      </div>
    </div>
  </div>
</section>
