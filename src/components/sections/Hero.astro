---
import ghIcon from "../../assets/icons/github-original.svg"
import Particles from "./Particles.svelte"
---

<section
  class="relative z-0 flex min-h-[calc(82svh-4rem)] overflow-hidden border-b border-line/70 bg-bg px-5 sm:px-8"
>
  <Particles client:load />
  <div
    class="mx-auto flex w-full max-w-6xl flex-col justify-center py-20 sm:py-24"
  >
    <div class="max-w-4xl">
      <p class="animate-fade-in-up font-code text-sm text-accent uppercase">
        Project delivery / Web development
      </p>
      <h1
        class="animate-fade-in-up mt-5 font-secondary text-[clamp(3.75rem,10vw,7.5rem)] leading-[0.8] font-bold text-white [animation-delay:100ms]"
      >
        Hey, I'm Aser.
      </h1>
      <p
        class="animate-fade-in-up mt-9 max-w-3xl text-3xl leading-tight font-semibold text-gray-200 sm:text-4xl lg:text-5xl [animation-delay:180ms]"
      >
        I build practical tools for security, public data and the web.
      </p>
      <div
        class="animate-fade-in-up mt-9 flex flex-wrap gap-3 [animation-delay:260ms]"
      >
        <a
          class="inline-flex min-h-12 items-center justify-center rounded-md bg-accent px-5 py-3 font-semibold text-bg transition-colors hover:bg-white motion-reduce:transition-none"
          href="#projects"
        >
          Explore projects
        </a>
        <a
          class="inline-flex min-h-12 items-center justify-center gap-3 rounded-md border border-line bg-surface px-5 py-3 font-semibold text-white transition-colors hover:border-accent hover:bg-surface-hover motion-reduce:transition-none"
          href="https://www.github.com/slicedearth"
          rel="noopener noreferrer"
          target="_blank"
          data-github-profile-link
        >
          <img class="h-5 w-5" src={ghIcon.src} alt="" loading="eager" />
          <span>GitHub profile</span>
        </a>
      </div>
    </div>

    <ul
      class="mt-16 hidden grid-cols-3 border-y border-line font-code text-xs text-muted uppercase sm:grid"
      aria-label="Areas of focus"
    >
      <li class="py-4">Security tools</li>
      <li class="border-x border-line px-5 py-4 text-center">Public data</li>
      <li class="py-4 text-right">Interactive web</li>
    </ul>
  </div>
</section>

<script>
  document
    .querySelector("[data-github-profile-link]")
    ?.addEventListener("click", () => {
      window.gtag?.("event", "select_content", {
        content_type: "github_profile_link",
        item_id: "hero",
      })
    })
</script>
