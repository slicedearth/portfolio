---
import ghIcon from "../../assets/icons/github-original.svg"
import Particles from "./Particles.svelte"
---

<section class="relative z-0 overflow-hidden bg-bg py-32">
  <div class="absolute top-1/3 left-1/2 -z-20 h-96 w-96 -translate-x-2/3 -translate-y-1/2 rounded-full bg-accent/20 blur-3xl"></div>
  <div class="absolute top-1/2 left-1/2 -z-20 h-96 w-96 -translate-y-1/3 translate-x-1/3 rounded-full bg-accent-2/20 blur-3xl"></div>
  <Particles client:load />
  <div class="mx-auto max-w-3xl px-4 text-center">
    <p class="animate-fade-in-up text-sm font-semibold tracking-widest text-accent uppercase">
      Welcome
    </p>
    <h1 class="animate-fade-in-up mt-2 font-secondary text-6xl font-bold text-white drop-shadow-[0_2px_20px_rgba(34,211,238,0.25)]">
      Hey, I'm Aser
    </h1>
    <h2 class="animate-fade-in-up mt-4 font-primary text-3xl text-gray-200 [animation-delay:150ms]">
      Project Manager/Web Developer
    </h2>
    <div class="animate-fade-in-up mt-10 [animation-delay:300ms]">
      <a
        class="inline-flex items-center gap-3 rounded-full border border-white/10 bg-slate-800 px-6 py-3 text-lg font-semibold text-white shadow-lg transition-all duration-300 hover:-translate-y-0.5 hover:border-accent/50 hover:bg-slate-700 hover:shadow-xl hover:shadow-accent/10"
        href="https://www.github.com/slicedearth"
        rel="noopener noreferrer"
        target="_blank"
        data-github-profile-link
      >
        <img class="h-5 w-5" src={ghIcon.src} alt="GitHub Icon" loading="eager" />
        <span>GitHub Profile</span>
      </a>
    </div>
  </div>
  <svg
    class="animate-bounce-slow absolute bottom-6 left-1/2 h-6 w-6 -translate-x-1/2 text-gray-500"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
  </svg>
</section>

<script>
  document.querySelector("[data-github-profile-link]")?.addEventListener("click", () => {
    window.gtag?.("event", "select_content", {
      content_type: "github_profile_link",
      item_id: "hero",
    })
  })
</script>
