---
import { getCollection } from "astro:content"
import ProjectItem from "./ProjectItem.astro"

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order
)
const images = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/images/projects/*.png",
  { eager: true }
)
---

<section id="projects" class="bg-surface/40 px-4 py-20">
  <div class="mb-12 text-center">
    <p class="text-sm font-semibold tracking-widest text-accent uppercase">
      My Work
    </p>
    <h2 class="mt-2 text-4xl font-bold text-white">Projects</h2>
    <div
      class="mx-auto mt-4 h-1 w-16 rounded-full bg-gradient-to-r from-accent to-accent-2"
    >
    </div>
  </div>
  <div class="mx-auto max-w-5xl">
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        projects.map(project => (
          <ProjectItem
            title={project.data.title}
            image={
              images[`../../assets/images/projects/${project.data.image}`]
                .default
            }
            imageAlt={project.data.image_alt}
            description={project.data.description}
            githubURL={project.data.githubURL}
            deployedURL={project.data.deployedURL}
          />
        ))
      }
    </div>
  </div>
</section>

<script>
  document.getElementById("projects")?.addEventListener("click", event => {
    const link = (event.target as HTMLElement).closest<HTMLElement>(
      "[data-project-link]"
    )
    const project = link?.dataset.projectLink
    const destination = link?.dataset.projectDestination
    if (!project || !destination) return

    window.gtag?.("event", "select_content", {
      content_type: `project_${destination}_link`,
      item_id: project,
    })
  })
</script>
