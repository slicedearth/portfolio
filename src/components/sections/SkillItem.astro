---
interface Props {
  title: string
  icon: ImageMetadata
  iconAlt: string
}

const { title, icon, iconAlt } = Astro.props
---

<div
  class="group flex min-h-12 min-w-0 items-center gap-2.5 rounded-md border border-line bg-card p-2 transition-colors duration-200 hover:border-accent/50 hover:bg-surface-hover motion-reduce:transition-none"
>
  <div
    class="flex h-8 w-8 shrink-0 items-center justify-center rounded-sm bg-gray-100 p-1.5"
  >
    <img class="h-full w-full" src={icon.src} alt={iconAlt} loading="lazy" />
  </div>
  <p class="min-w-0 text-sm leading-tight font-medium text-gray-200">
    {title}
  </p>
</div>
