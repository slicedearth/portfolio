---
const year = new Date().getFullYear()
---

<footer class="bg-surface px-5 py-8 text-sm text-muted sm:px-8">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-4 border-t border-line pt-6 sm:flex-row sm:items-end sm:justify-between"
  >
    <div>
      <p class="font-secondary text-3xl font-bold text-accent">Abymar</p>
      <p class="mt-1">&copy; slicedearth {year}</p>
    </div>
    <p class="sm:text-right">
      Built with{" "}
      <a
        href="https://astro.build/"
        rel="noopener noreferrer"
        target="_blank"
        class="font-semibold text-gray-200 transition-colors hover:text-accent motion-reduce:transition-none"
      >
        Astro
      </a>{" "}
      and{" "}
      <a
        href="https://tailwindcss.com"
        rel="noopener noreferrer"
        target="_blank"
        class="font-semibold text-gray-200 transition-colors hover:text-accent motion-reduce:transition-none"
      >
        Tailwind CSS
      </a>.
    </p>
  </div>
</footer>
